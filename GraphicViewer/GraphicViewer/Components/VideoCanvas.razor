@using GraphicViewer.Models
@inject IJSRuntime JS

<div class="svg-canvas-wrap video-canvas-wrap">
    @if (CurrentFile is not null)
    {
        <div class="video-frame">
            <video @key="CurrentFile.ObjectUrl"
                   src="@CurrentFile.ObjectUrl"
                   class="video-player"
                   controls
                   preload="metadata"
                   @onplay="HandlePlay"
                   @onpause="HandlePause"
                   @onended="HandleEnded"
                   @ref="_videoRef">
                <source src="@CurrentFile.ObjectUrl" type="@CurrentFile.MimeType" />
                Your browser does not support the video tag.
            </video>
        </div>
    }
    else
    {
        <div class="canvas-empty">
            <span class="empty-icon">
                <i class="ti ti-player-play" style="font-size:64px;opacity:0.2" aria-hidden="true"></i>
            </span>
            <p>Open a folder to load videos</p>
            <small>Supports MP4, WEBM, OGV, MOV, AVI</small>
        </div>
    }

    <button class="nav-btn nav-prev"
            disabled="@(!CanGoPrev)"
            @onclick="HandlePrev"
            @onclick:stopPropagation="true"
            aria-label="Previous video">&#8249;</button>

    <button class="nav-btn nav-next"
            disabled="@(!CanGoNext)"
            @onclick="HandleNext"
            @onclick:stopPropagation="true"
            aria-label="Next video">&#8250;</button>
</div>

@code {
    [Parameter] public VideoFileModel? CurrentFile { get; set; }
    [Parameter] public bool CanGoPrev { get; set; }
    [Parameter] public bool CanGoNext { get; set; }
    [Parameter] public EventCallback OnPrev { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }
    [Parameter] public EventCallback<bool> OnPlayStateChanged { get; set; }

    private ElementReference _videoRef;

    private async Task HandlePrev()
    {
        await StopVideo();
        await OnPrev.InvokeAsync();
    }

    private async Task HandleNext()
    {
        await StopVideo();
        await OnNext.InvokeAsync();
    }

    private async Task StopVideo()
    {
        try
        {
            await JS.InvokeVoidAsync("GraphicViewer.stopVideo", _videoRef);
        }
        catch { /* ignore */ }
    }

    private async Task HandlePlay()
        => await OnPlayStateChanged.InvokeAsync(true);

    private async Task HandlePause()
        => await OnPlayStateChanged.InvokeAsync(false);

    private async Task HandleEnded()
        => await OnPlayStateChanged.InvokeAsync(false);
}
