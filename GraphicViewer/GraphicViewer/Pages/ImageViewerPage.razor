@page "/image-viewer"
@using Microsoft.AspNetCore.Components.Forms
@using GraphicViewer.Models
@using GraphicViewer.Services
@using GraphicViewer.Components
@inject ImageViewerService ViewerService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>PNG/JPEG Viewer — GraphicViewer</PageTitle>

<div class="app-shell" @onkeydown="HandleKeyDown" tabindex="0" @ref="_appRef">

    <div class="titlebar">
        <div class="window-dots">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
        </div>
        <span class="titlebar-name">PNG / JPEG Viewer</span>
        <span class="titlebar-meta">
            @(ViewerService.HasFiles ? $"{ViewerService.Files.Count} images" : "no folder loaded")
        </span>
    </div>

    <ImageToolbar ZoomLabel="@ViewerService.ZoomLabel"
                  FileCounter="@ViewerService.FileCounter"
                  HasFiles="@ViewerService.HasFiles"
                  OnFilesSelected="HandleFilesSelected"
                  OnZoomIn="@(() => ViewerService.ZoomIn())"
                  OnZoomOut="@(() => ViewerService.ZoomOut())"
                  OnZoomReset="@(() => ViewerService.ResetZoom())"
                  OnCopy="HandleCopy"
                  OnDownload="HandleDownload" />

    <div class="main-layout">

        <aside class="sidebar">
            @if (ViewerService.HasFiles)
            {
                <SearchBar Value="@_searchTerm"
                           ValueChanged="OnSearchChanged"
                           Placeholder="search images..." />
            }
            else
            {
                <div class="sidebar-header">images</div>
            }

            @if (!ViewerService.HasFiles)
            {
                <div class="sidebar-empty">
                    <span style="font-size:32px;opacity:0.4">🖼</span>
                    <p>Open a folder<br />to get started</p>
                </div>
            }
            else if (!FilteredFiles.Any())
            {
                <div class="sidebar-empty">
                    <span style="font-size:20px">🔍</span>
                    <p>No files match<br />"@_searchTerm"</p>
                </div>
            }
            else
            {
                @foreach (var file in FilteredFiles)
                {
                    <ImageThumbnail File="file"
                                    IsActive="file.Index == ViewerService.CurrentIndex"
                                    OnClick="@(() => ViewerService.SelectFile(file.Index))" />
                }
            }
        </aside>

        <div class="viewer-column">
            <ImageCanvas CurrentFile="ViewerService.CurrentFile"
                         ZoomLevel="@ViewerService.ZoomLevel"
                         CanGoPrev="@ViewerService.CanGoPrev"
                         CanGoNext="@ViewerService.CanGoNext"
                         OnPrev="@(() => ViewerService.NavigatePrev())"
                         OnNext="@(() => ViewerService.NavigateNext())" />

            <ImageStatusBar CurrentFile="ViewerService.CurrentFile"
                            FileCounter="@ViewerService.FileCounter" />
        </div>

    </div>
</div>

@code {
    private ElementReference _appRef;
    private string _searchTerm = string.Empty;

    private IEnumerable<ImageFileModel> FilteredFiles =>
        string.IsNullOrWhiteSpace(_searchTerm)
            ? ViewerService.Files
            : ViewerService.Files.Where(f =>
                f.FileName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        ViewerService.OnStateChanged += OnViewerStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await _appRef.FocusAsync();
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        _searchTerm = string.Empty;
        await ViewerService.LoadFilesAsync(e.GetMultipleFiles(500));
    }

    private async Task HandleCopy()
    {
        await ViewerService.CopyFileNameAsync();
    }

    private async Task HandleDownload()
    {
        if (ViewerService.CurrentFile is null) return;

        // Trigger browser download via JS
        await JS.InvokeVoidAsync("GraphicViewer.downloadImage",
            ViewerService.CurrentFile.DataUrl,
            ViewerService.CurrentFile.FileName);
    }

    private void OnSearchChanged(string value) => _searchTerm = value;

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowLeft": ViewerService.NavigatePrev(); break;
            case "ArrowRight": ViewerService.NavigateNext(); break;
            case "+": case "=": ViewerService.ZoomIn(); break;
            case "-": ViewerService.ZoomOut(); break;
            case "0": ViewerService.ResetZoom(); break;
        }
    }

    private void OnViewerStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ViewerService.OnStateChanged -= OnViewerStateChanged;
    }
}
